# Marketing Automation MCP configuration

google_ads:
  enabled: false
  timeout: 30
  retry_attempts: 3
  retry_delay: 1

facebook_ads:
  enabled: false
  timeout: 30
  retry_attempts: 3
  retry_delay: 2

google_analytics:
  enabled: false
  timeout: 45
  retry_attempts: 2

ai:
  provider: "openai"
  demo_mode: true
  openai:
    model: "gpt-5.4"
    max_tokens: 4000
    temperature: 0.2
  anthropic:
    model: ""
    max_tokens: 4000
    temperature: 0.2
  gemini:
    model: ""
    max_tokens: 4000
    temperature: 0.2

database:
  pool_size: 5
  max_overflow: 10
  pool_timeout: 30
  echo: false

security:
  api_key_encryption: true
  audit_logging: true
  allowed_origins:
    - "*"
  secure_headers: true

performance:
  cache_enabled: true
  cache_ttl: 3600
  batch_size: 100
  concurrent_requests: 5
  request_timeout: 30
  slow_query_threshold: 1.0

logging:
  level: "INFO"
  format: "json"
  file: "logs/marketing_automation.log"
  max_size: 10485760
  backup_count: 5
  structured: true
